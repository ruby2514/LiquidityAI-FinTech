{
  "name": "liquidity-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/server.js\"",
    "dev:frontend": "vite",
    "dev:backend": "node server/server.js",
