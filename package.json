    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "uuid": "^10.0.0",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.2.0",
    "concurrently": "^9.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
